# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Your WhatsApp number in international format WITHOUT the + sign
# Example: 2348012345678
WHATSAPP_NUMBER=

# ── AI KEYS (at least ONE required) ──────────────────────────────────────────
# Amòfin tries these in order: Gemini → Groq → Nvidia
# Add all three for maximum reliability

# Google Gemini (Primary) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (Fallback 1) — https://console.groq.com/keys
GROQ_API_KEY=

# Nvidia NIM (Fallback 2) — https://build.nvidia.com/
NVIDIA_API_KEY=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Your WhatsApp number (for admin-only commands like announcements)
# Can be comma-separated for multiple admins: 2348012345678,2348098765432
ADMIN_NUMBER=

# Pre-set the group JID if known (format: 120363XXXXXXXXXX@g.us)
# If not set, Amòfin auto-detects it from the first group message
GROUP_JID=

# Port for the keep-alive server (default: 3000)
PORT=3000
