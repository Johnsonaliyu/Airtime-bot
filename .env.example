# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your WhatsApp number in international format WITHOUT the + sign
# Example: 2348012345678
WHATSAPP_NUMBER=

# Peyflex API token — from https://client.peyflex.com.ng dashboard
PEYFLEX_TOKEN=

# ── AI KEYS (at least ONE required) ───────────────────────────────────────────
# The bot tries these in order: Groq → Nvidia → Manus → Gemini
# Add all for maximum reliability

# Groq (Primary scorer) — https://console.groq.com/keys
GROQ_API_KEY=

# Nvidia NIM (Fallback 1) — https://build.nvidia.com/
NVIDIA_API_KEY=

# Manus (Fallback 2) — from your Manus account
MANUS_API_KEY=
# Optional: override Manus base URL and model
# MANUS_BASE_URL=https://api.manus.im/v1
# MANUS_MODEL=manus-default

# Google Gemini (Fallback 3) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Airtime amount per winner in Naira (default: 100)
AIRTIME_AMOUNT=100

# Admin WhatsApp number(s) for group commands (comma-separated)
ADMIN_NUMBER=

# Pre-set the group JID if known (format: 120363XXXXXXXXXX@g.us)
GROUP_JID=

# Port for the keep-alive server (default: 3000)
PORT=3000
